# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/vagas

# JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Adzuna API — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Evolution API (WhatsApp gateway)
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=

# SMTP — envio de email (recuperação de senha)
# Para Gmail: use uma "senha de app" em myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
FRONTEND_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
